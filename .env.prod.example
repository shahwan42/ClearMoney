# ClearMoney Production Configuration

# Server
PORT=8080
ENV=production

# Database (used by Go app)
DATABASE_URL=postgres://clearmoney:CHANGE_ME@db:5432/clearmoney?sslmode=disable

# PostgreSQL (used by the db container)
POSTGRES_USER=clearmoney
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=clearmoney

# Auth — Magic Link via Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@clearmoney.app
APP_URL=https://clearmoney.shahwan.me
MAX_DAILY_EMAILS=50
