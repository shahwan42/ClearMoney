# ClearMoney reverse proxy configuration.
#
# Strangler Fig pattern: specific migrated routes go to Django,
# everything else stays on Go. Both apps share the same domain
# and session cookie, so users see a seamless experience.
#
# To roll back: remove the Django handle blocks and restart Caddy.
# Go still serves all routes, so rollback is instant.

clearmoney.shahwan.me {
	# Migrated routes → Django (port 8000)
	handle /settings {
		reverse_proxy django:8000
	}
	handle /export/* {
		reverse_proxy django:8000
	}
	handle /reports {
		reverse_proxy django:8000
	}
	handle /accounts* {
		reverse_proxy django:8000
	}
	handle /institutions/* {
		reverse_proxy django:8000
	}
	handle /transactions* {
		reverse_proxy django:8000
	}
	handle /transfers/* {
		reverse_proxy django:8000
	}
	handle /exchange/* {
		reverse_proxy django:8000
	}
	handle /fawry-cashout {
		reverse_proxy django:8000
	}
	handle /batch-entry {
		reverse_proxy django:8000
	}
	handle /sync/* {
		reverse_proxy django:8000
	}
	handle /api/transactions/* {
		reverse_proxy django:8000
	}
	handle /people* {
		reverse_proxy django:8000
	}
	handle /api/persons* {
		reverse_proxy django:8000
	}
	handle /budgets* {
		reverse_proxy django:8000
	}
	handle /virtual-accounts* {
		reverse_proxy django:8000
	}
	handle /virtual-funds* {
		reverse_proxy django:8000
	}
	handle /recurring* {
		reverse_proxy django:8000
	}
	handle /salary* {
		reverse_proxy django:8000
	}
	handle /investments* {
		reverse_proxy django:8000
	}
	handle /exchange-rates {
		reverse_proxy django:8000
	}

	# Everything else → Go (port 8080)
	handle {
		reverse_proxy app:8080
	}
}
