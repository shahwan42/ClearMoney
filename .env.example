# ClearMoney Configuration

ENV=development

# Database
DATABASE_URL=postgres://clearmoney:clearmoney@db:5432/clearmoney?sslmode=disable

# PostgreSQL (used by the db container)
POSTGRES_USER=clearmoney
POSTGRES_PASSWORD=clearmoney
POSTGRES_DB=clearmoney

# Auth — Magic Link via Resend
# Leave RESEND_API_KEY empty for dev mode (magic links logged to console, not emailed)
RESEND_API_KEY=
EMAIL_FROM=noreply@clearmoney.app
APP_URL=http://localhost:8000
MAX_DAILY_EMAILS=50

# Push Notifications — Web Push API with VAPID
# Generate keys with: python manage.py generate_vapid_keys
# No external services required — purely local push notifications via polling.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
