#!/usr/bin/env bash
set -e

# Run ruff format + lint check on staged Python files under backend/
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

# Only process files that live under backend/ (e2e/ uses its own tooling)
BACKEND_PY=$(echo "$STAGED_PY" | grep '^backend/' | sed 's|^backend/||' || true)

if [ -n "$BACKEND_PY" ]; then
    cd backend

    if ! uv run ruff format --check $BACKEND_PY 2>/dev/null; then
        echo "❌ ruff format check failed. Run: cd backend && uv run ruff format ."
        exit 1
    fi

    if ! uv run ruff check $BACKEND_PY 2>/dev/null; then
        echo "❌ ruff lint check failed. Run: cd backend && uv run ruff check --fix ."
        exit 1
    fi

    if ! DATABASE_URL="postgres://clearmoney:clearmoney@localhost:5433/clearmoney?sslmode=disable" uv run mypy $BACKEND_PY 2>/dev/null; then
        echo "❌ mypy type check failed. Run: cd backend && uv run mypy ."
        exit 1
    fi
fi
