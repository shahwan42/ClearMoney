#!/usr/bin/env bash
set -e

# Run ruff format + lint check on staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY" ]; then
    # Strip backend/ prefix for ruff (runs from backend/)
    BACKEND_PY=$(echo "$STAGED_PY" | sed 's|^backend/||')

    cd backend

    if ! uv run ruff format --check $BACKEND_PY 2>/dev/null; then
        echo "❌ ruff format check failed. Run: cd backend && uv run ruff format ."
        exit 1
    fi

    if ! uv run ruff check $BACKEND_PY 2>/dev/null; then
        echo "❌ ruff lint check failed. Run: cd backend && uv run ruff check --fix ."
        exit 1
    fi
fi
